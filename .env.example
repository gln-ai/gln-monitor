# ── 필수: 네이버 개발자센터에서 발급 ──────────────────────────────────────────
# https://developers.naver.com → 애플리케이션 등록 → 검색 API 신청
NAVER_CLIENT_ID=여기에_클라이언트_ID_입력
NAVER_CLIENT_SECRET=여기에_클라이언트_시크릿_입력

# ── 필수: Anthropic 콘솔에서 발급 ────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-여기에_키_입력

# ── 이메일 (선택 — Gmail 사용 시) ────────────────────────────────────────────
# Gmail → 구글 계정 → 보안 → 2단계 인증 ON → 앱 비밀번호 생성
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx   # 앱 비밀번호 (일반 비밀번호 아님!)
REPORT_FROM=your-gmail@gmail.com
REPORT_TO=받을-이메일@gmail.com   # 리포트 수신 주소
